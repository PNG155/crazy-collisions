extends Button

var precio_final = 0
var random = 0
var precio_base = 0
var random2 

func actualizar_precio():
	if GameManager.run < 3:
		precio_base = 20
	elif GameManager.run < 6:
		precio_base = 50
	elif GameManager.run < 13:
		precio_base = 100
	else:
		precio_base = 200
	
	precio_final = precio_base * randf_range(0.5, 1.5)
	
	print(precio_final)
	if precio_final < 10: 
		precio_final = 10 


func _ready():
	actualizar_precio()
	GameManager.bloquear_compra()


func _on_mouse_entered() -> void:
	$Sprite2D2.show()
	$Label.show()


func _on_mouse_exited() -> void:
	$Sprite2D2.hide()
	$Label.hide()


func _on_button_down() -> void:
	print("CLICK")
	if GameManager.money >= precio_final and GameManager.podes_comprar:
		print("buy it")
		print(precio_final)
		
		random2 = randi_range(1,3)
		if random2 == 1:
			GameManager.multi += 1
			$Label2.show()
			await get_tree().create_timer(1).timeout
		elif random2 == 2:
			GameManager.multi -= 2
			$Label3.show()
			await get_tree().create_timer(1).timeout
		else:
			GameManager.money -= 10
			$Label4.show()
			await get_tree().create_timer(1).timeout
		
		get_parent().queue_free()
		print(get_parent())
	else:
		print("poor")
		print(precio_final)
		return
