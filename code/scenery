extends Node2D

#random music:

const musica_random= [
	"res://musica retro/musica retro.mp3",
	"res://musica retro/musica retro2.wav",
	"res://musica retro/musica retro3.wav",
	"res://musica retro/musica retro4.wav",
	"res://musica retro/musica retro5.wav",
	"res://musica retro/musica retro6.wav",
	"res://musica retro/musica retro7.mp3",
]

@export var ball : PackedScene
@onready var musica: AudioStreamPlayer = $musica

func play_random() -> void:
	var song_to_play = randi_range(0, musica_random.size() -1)
	musica.stream = load(musica_random[song_to_play])
	musica.play()

func _ready() -> void:
	bucle()
	play_random()
	musica.finished.connect(_on_music_finished)


func _on_music_finished() -> void:
	play_random()




#actions:

func _input(event):
	if event.is_action_pressed("esc"):
		var objeto = preload("res://esc.tscn").instantiate()
		get_node("Camera2D/CanvasLayer2").add_child(objeto)
		get_tree().paused = !get_tree().paused
		
	if event.is_action_pressed("click"):
			var nueva_pelota = ball.instantiate()
			nueva_pelota.position = get_global_mouse_position()
			add_child(nueva_pelota)


#powers amazing:

@onready var screen_size = get_viewport().get_visible_rect().size

func super_poder():
	
	var x_random = randi_range(0, int(screen_size.x))
	var y_random = randi_range(0, int(screen_size.y))
	
	var mejora = preload("res://mejora.tscn").instantiate()
	mejora.position = Vector2(x_random, y_random)
	add_child(mejora)


func bucle():
	super_poder()
	await get_tree().create_timer(10).timeout
	bucle()
