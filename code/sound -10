
extends Label

func _ready() -> void:

	$Button2.button_down.connect(_on_button_down)

func _on_button_down() -> void:
	if AudioServer.get_bus_volume_db(AudioServer.get_bus_index("Master")) > -40:
		var volumen_actual = AudioServer.get_bus_volume_db(AudioServer.get_bus_index("Master")) 
		AudioServer.set_bus_volume_db(AudioServer.get_bus_index("Master"), volumen_actual - 10)

