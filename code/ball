extends RigidBody2D

@onready var area = $Area2D	
var puede_sumar := true

func _ready():
	area.area_entered.connect(_on_area_entered)
	area.area_exited.connect(_on_area_exited)


func _on_area_entered(area):
	if self.get_instance_id() < area.get_instance_id() and puede_sumar == true:
		var ball1 = obtener_puntos(self)
		var ball2 = obtener_puntos(area.get_parent())
		
		
		var resultados: int = max(ball1, ball2)
		GameManager.colisiones_totales += resultados
		print(resultados)
		puede_sumar = false

func obtener_puntos(objeto):
	if objeto.is_in_group("maxing_supreme"):
		return GameManager.maxing_supreme_plus
	elif objeto.is_in_group("legendary"):
		return GameManager.legendary_plus
	elif objeto.is_in_group("rare"):
		return GameManager.rare_plus
	elif objeto.is_in_group("ball"):
		return GameManager.common_plus
	return 0


func _on_area_exited(area):
	puede_sumar = true
				
