extends Label


func _process(delta):
	text = "requirement: " + str(GameManager.requirement)
	if ((GameManager.colisiones_totales * GameManager.multi) == GameManager.requirement):
		await get_tree().create_timer(0.15).timeout
		GameManager.requirement += GameManager.requirement*1.65
		get_tree().change_scene_to_file("res://shop.tscn")
		get_parent().get_node("Label2").objetivo_conseguido()
