extends Sprite2D

var color_original = modulate

func _ready() -> void:
	$Button333.mouse_entered.connect(_on_mouse_entered)
	$Button333.mouse_exited.connect(_on_mouse_exited)
	$Button333.button_down.connect(_on_button_button_down)
	
func _on_mouse_exited() -> void:
	modulate = color_original

func _on_mouse_entered() -> void:
	modulate = Color.LIGHT_STEEL_BLUE

func _on_button_button_down() -> void:
	await get_tree().create_timer(0.2).timeout
	var objeto = preload("res://sound.tscn").instantiate()
	get_parent().add_child(objeto)
