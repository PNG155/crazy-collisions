extends Button

@onready var posicion_original 
@onready var posicion_original2 

func _ready():
	posicion_original  = $Sprite2D.global_position 
	posicion_original2  = $Label.global_position 
func _on_mouse_entered() -> void:
	$Sprite2D.show()
	$Label.show()
	
	var screen_size = get_viewport_rect().size
	var ancho = $Sprite2D.texture.get_size().x * $Sprite2D.scale.x
	
	if $Sprite2D.global_position.x + ancho > screen_size.x:
		$Sprite2D.flip_h = true 
		$Sprite2D.global_position = posicion_original - Vector2(400, 0)
		$Label.global_position = posicion_original2 - Vector2(430, 0)


func _on_mouse_exited() -> void:
	$Sprite2D.hide()
	$Label.hide()
	$Sprite2D.global_position = posicion_original 
	$Label.global_position = posicion_original2
