extends Button

var valuer:int = 0
var random = 0
var precio_final = 0
var precio_base = 0
func actualizar_precio():
	precio_base = 23 + GameManager.run * 15
	precio_final = precio_base * randf_range(0.9, 1.1)
	print(valuer)
	if precio_final < 10: 
		precio_final = 10 


func _ready():
	random = randf_range(0.85, 1.15)
	actualizar_precio()

func _on_mouse_entered() -> void:
	$Sprite2D2.show()
	$Label.show()


func _on_mouse_exited() -> void:
	$Sprite2D2.hide()
	$Label.hide()


func _on_button_down() -> void:
	print("CLICK")
	if GameManager.money >= precio_final:
		print ("buy it")
		print(precio_final)
		GameManager.bond += 6
		
		
		GameManager.money -= precio_final
		get_parent().queue_free()
		print(get_parent())
	else:
		print ("poor")
		print(precio_final)
		return

