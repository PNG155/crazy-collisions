extends Button

var valuer:int = 0

func _ready():
	valuer = int(GameManager.money / 2)
	print(valuer)
	if valuer <= 9: 
		valuer = 10 

func _on_button_down() -> void:
	print("CLICK")
	if GameManager.money >= valuer:
		print ("buy it")
		print(valuer)
		GameManager.multi += 1
		GameManager.money -= valuer
		queue_free()
		get_tree().change_scene_to_file("res://escenario.tscn")
	else:
		print ("poor")
		print(valuer)
		


func _on_mouse_entered() -> void:
	$Sprite2D2.show()
	$Label.show()
	


func _on_mouse_exited() -> void:
	$Sprite2D2.hide()
	$Label.hide()
