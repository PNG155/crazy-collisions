extends Button

var valuer:int = 0

func actualizar_precio():
	valuer = int(GameManager.colisiones_totales * 1.4)
	print(valuer)
	if valuer <= 9: 
		valuer = 10 
	

func _ready():
	actualizar_precio()

func _process(delta):
	actualizar_precio()

func _on_button_down() -> void:
	print("CLICK")
	if GameManager.money >= valuer:
		print ("buy it")
		print(valuer)
		GameManager.multi += 1
		GameManager.money -= valuer
		get_parent().queue_free()
		print(get_parent())
		actualizar_precio()
	else:
		print ("poor")
		print(valuer)
		return
		

func _on_mouse_entered() -> void:
	$Sprite2D2.show()
	$Label.show()


func _on_mouse_exited() -> void:
	$Sprite2D2.hide()
	$Label.hide()
